<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

.hero{
    background: #fe424d;
    color:white;
    padding:60px 20px;
    border-radius:12px;
}

.feature-card{
    transition: all 0.3s;
}

.feature-card:hover{
    transform: translateY(-5px);
    box-shadow:0 10px 20px rgba(0,0,0,0.15);
}

.stat-box{
    background:#f8f9fa;
    border-radius:10px;
    padding:20px;
}

</style>

</head>

<body>

<div class="container mt-5">

<!-- HERO SECTION -->
<div class="hero text-center mb-5">
<h1 class="fw-bold">About Gobnb</h1>
<p class="lead">Helping you discover the perfect place to stay.</p>
</div>

<!-- ABOUT TEXT -->
<div class="row justify-content-center mb-5">
<div class="col-md-8 text-center">
<p class="text-muted">
<strong>Gobnb</strong> is a platform designed to help users find comfortable and
affordable accommodations easily. Our goal is to make searching for stays
simple, transparent, and convenient for everyone.
</p>

<p class="text-muted">
From short stays to long-term rentals, Gobnb provides verified listings
and clear information so you can make the best choice for your trip.
</p>
</div>
</div>

<!-- FEATURES -->
<div class="row text-center mb-5">

<div class="col-md-4">
<div class="card feature-card border-0 shadow-sm p-4">
<i class="fa-solid fa-house fa-2x text-primary mb-3"></i>
<h5>Verified Listings</h5>
<p class="text-muted">All properties are checked to ensure quality and trust.</p>
</div>
</div>

<div class="col-md-4">
<div class="card feature-card border-0 shadow-sm p-4">
<i class="fa-solid fa-location-dot fa-2x text-danger mb-3"></i>
<h5>Smart Location</h5>
<p class="text-muted">Find properties easily with accurate location details.</p>
</div>
</div>

<div class="col-md-4">
<div class="card feature-card border-0 shadow-sm p-4">
<i class="fa-solid fa-star fa-2x text-warning mb-3"></i>
<h5>Trusted Reviews</h5>
<p class="text-muted">Real feedback from users helps you choose better stays.</p>
</div>
</div>

</div>

<!-- STATS -->
<div class="row text-center">

<div class="col-md-4">
<div class="stat-box shadow-sm">
<h2 class="text-primary">500+</h2>
<p class="text-muted">Listings</p>
</div>
</div>

<div class="col-md-4">
<div class="stat-box shadow-sm">
<h2 class="text-primary">1000+</h2>
<p class="text-muted">Happy Users</p>
</div>
</div>

<div class="col-md-4">
<div class="stat-box shadow-sm">
<h2 class="text-primary">50+</h2>
<p class="text-muted">Cities</p>
</div>
</div>

</div>

</div>

</body>
</html>