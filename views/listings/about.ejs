<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

/* GLOBAL */
body{
font-family: 'Poppins', sans-serif;
background:#f8f9fa;
}

/* HERO */
.hero{
height:75vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
background:linear-gradient(135deg, rgba(0,0,0,0.6), rgba(0,0,0,0.2)),
url('https://images.unsplash.com/photo-1560347876-aeef00ee58a1?auto=format&fit=crop&w=1470&q=80')
no-repeat center/cover;
border-radius:25px;
margin-bottom:70px;
transition:0.4s ease;
}

.hero:hover{
transform:scale(1.01);
}

.hero h1{
font-size:3.2rem;
font-weight:700;
}

.hero p{
font-size:1.2rem;
opacity:0.9;
}

.hero .btn{
padding:12px 30px;
border-radius:50px;
background:linear-gradient(45deg,#ff4e50,#f9d423);
color:white;
font-weight:600;
border:none;
transition:0.3s;
}

.hero .btn:hover{
transform:translateY(-3px);
box-shadow:0 8px 20px rgba(0,0,0,0.3);
}

/* GLASS */
.glass{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(20px);
border-radius:20px;
padding:40px;
box-shadow:0 10px 30px rgba(0,0,0,0.3);
}

/* TITLES */
.section-title{
font-weight:700;
text-align:center;
margin-bottom:50px;
font-size:2.2rem;
}

/* STEPS */
.step{
text-align:center;
padding:25px;
border-radius:15px;
transition:0.3s;
}

.step:hover{
background:white;
transform:translateY(-8px);
box-shadow:0 10px 25px rgba(0,0,0,0.15);
}

.step-icon{
width:75px;
height:75px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
margin:auto;
background:linear-gradient(45deg,#ff4e50,#f9d423);
color:white;
font-size:26px;
margin-bottom:15px;
}

/* STATS */
.stat{
text-align:center;
padding:30px;
border-radius:15px;
background:white;
transition:0.3s;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
}

.stat:hover{
transform:translateY(-10px);
}

/* TEAM */
.team{
text-align:center;
padding:30px;
border-radius:15px;
background:white;
transition:0.3s;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
}

.team:hover{
transform:translateY(-10px);
}

.team img{
width:120px;
height:120px;
border-radius:50%;
margin-bottom:15px;
transition:0.3s;
}

.team:hover img{
transform:scale(1.1);
}

.social-icons a{
margin:0 8px;
color:#555;
font-size:18px;
}

.social-icons a:hover{
color:#ff4e50;
}

/* TESTIMONIAL */
.testimonial{
padding:25px;
border-radius:15px;
background:white;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
transition:0.3s;
}

.testimonial:hover{
transform:translateY(-8px);
}

/* ANIMATION */
.fade-in{
opacity:0;
transform:translateY(30px);
transition:0.8s;
}

.fade-in.show{
opacity:1;
transform:translateY(0);
}

</style>

</head>

<body>

<div class="container mt-5">

<!-- HERO -->
<div class="hero fade-in">
<div class="glass">
<h1>Welcome to Gobnb</h1>
<p>Discover amazing places to stay around the world</p>
<button class="btn">Explore Stays</button>
</div>
</div>

<!-- ABOUT -->
<div class="row justify-content-center mb-5 fade-in">
<div class="col-md-8 text-center">
<h2 class="section-title">Our Mission</h2>
<p class="text-muted fs-5">
Gobnb helps travelers discover <strong>affordable and trusted stays</strong>.
We make booking simple, secure, and fast.
</p>
</div>
</div>

<!-- HOW IT WORKS -->
<h2 class="section-title fade-in">How Gobnb Works</h2>
<div class="row mb-5 fade-in">
<div class="col-md-4 step">
<div class="step-icon"><i class="fa-solid fa-search"></i></div>
<h5>Search</h5>
<p class="text-muted">Explore thousands of listings easily.</p>
</div>

<div class="col-md-4 step">
<div class="step-icon"><i class="fa-solid fa-star"></i></div>
<h5>Compare</h5>
<p class="text-muted">Check ratings and reviews.</p>
</div>

<div class="col-md-4 step">
<div class="step-icon"><i class="fa-solid fa-house"></i></div>
<h5>Book</h5>
<p class="text-muted">Reserve instantly.</p>
</div>
</div>

<!-- STATS -->
<h2 class="section-title fade-in">Platform Stats</h2>
<div class="row mb-5 fade-in">
<div class="col-md-4 mb-3">
<div class="stat">
<h2 class="text-danger">500+</h2>
<p>Listings</p>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="stat">
<h2 class="text-success">1000+</h2>
<p>Happy Users</p>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="stat">
<h2 class="text-primary">50+</h2>
<p>Cities</p>
</div>
</div>
</div>

</div>

<!-- SCROLL ANIMATION SCRIPT -->
<script>
const elements = document.querySelectorAll('.fade-in');

window.addEventListener('scroll', () => {
elements.forEach(el => {
const rect = el.getBoundingClientRect();
if(rect.top < window.innerHeight - 100){
el.classList.add('show');
}
});
});
</script>

</body>