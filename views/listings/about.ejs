<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- FONT -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- ICONS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

/* GLOBAL */
body{
  font-family:'Inter', sans-serif;
  background:#ffffff;
  color:#1d1d1f;
  line-height:1.6;
}
.container{
  max-width:1000px;
}

/* DARK MODE */
body.dark{
  background:#000;
  color:#f5f5f7;
}
body.dark .card{
  background:#111;
  border:1px solid #222;
}

/* TOGGLE */
.toggle-btn{
  position:fixed;
  top:20px;
  right:20px;
  background:#f5f5f7;
  border:none;
  padding:8px 14px;
  border-radius:20px;
  cursor:pointer;
}

/* HERO */
.hero{
  height:75vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
}
.hero h1{
  font-size:3.2rem;
  font-weight:600;
}
.hero p{
  color:#6e6e73;
  margin-top:10px;
}

/* BUTTON */
.btn{
  margin-top:20px;
  padding:10px 22px;
  border-radius:50px;
  border:1px solid #d2d2d7;
  background:white;
  cursor:pointer;
}
.btn:hover{
  background:#f5f5f7;
}

/* TITLES */
.section-title{
  text-align:center;
  font-size:2rem;
  font-weight:600;
  margin:80px 0 40px;
}

/* CARDS */
.card{
  padding:30px;
  border-radius:18px;
  background:#fafafa;
  border:1px solid #e5e5e7;
  transition:0.3s;
}
.card:hover{
  transform:translateY(-5px);
}

/* ICON */
.icon{
  font-size:22px;
  margin-bottom:10px;
  color:#6e6e73;
}

/* TEXT */
p{
  color:#6e6e73;
}

/* STATS */
.stat-number{
  font-size:2rem;
  font-weight:600;
}

/* ANIMATION */
.fade{
  opacity:0;
  transform:translateY(30px);
  transition:0.8s;
}
.fade.show{
  opacity:1;
  transform:translateY(0);
}

</style>
</head>

<body>

<button class="toggle-btn" onclick="toggleDark()">☾</button>

<div class="container">

<!-- HERO -->
<div class="hero fade">
  <div>
    <h1>Gobnb</h1>
    <p>Find places that feel like home</p>
    <button class="btn" onclick="scrollToStats()">Explore</button>
  </div>
</div>

<!-- ABOUT -->
<div class="fade text-center">
  <h2 class="section-title">Our Mission</h2>
  <p>
    We help people discover simple, reliable, and affordable stays around the world.
  </p>
</div>

<!-- STEPS -->
<h2 class="section-title fade">How it works</h2>
<div class="row text-center fade">

  <div class="col-md-4">
    <div class="card">
      <div class="icon"><i class="fa-solid fa-search"></i></div>
      <h5>Search</h5>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="icon"><i class="fa-solid fa-star"></i></div>
      <h5>Compare</h5>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="icon"><i class="fa-solid fa-house"></i></div>
      <h5>Book</h5>
    </div>
  </div>

</div>

<!-- STATS -->
<h2 class="section-title fade" id="stats">Stats</h2>
<div class="row text-center fade">

  <div class="col-md-4">
    <div class="card">
      <div class="stat-number counter" data-target="500">0</div>
      <p>Listings</p>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="stat-number counter" data-target="1000">0</div>
      <p>Users</p>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="stat-number counter" data-target="50">0</div>
      <p>Cities</p>
    </div>
  </div>

</div>

</div>

<script>

/* DARK MODE */
function toggleDark(){
  document.body.classList.toggle("dark");
}

/* SCROLL */
function scrollToStats(){
  document.getElementById("stats").scrollIntoView({behavior:"smooth"});
}

/* FADE */
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add("show");
    }
  });
});
document.querySelectorAll(".fade").forEach(el=>obs.observe(el));

/* COUNTER */
document.querySelectorAll('.counter').forEach(counter=>{
  let update=()=>{
    let target=+counter.dataset.target;
    let current=+counter.innerText;
    let inc=target/100;

    if(current<target){
      counter.innerText=Math.ceil(current+inc);
      setTimeout(update,20);
    } else {
      counter.innerText=target;
    }
  }
  update();
});

</script>

</body>