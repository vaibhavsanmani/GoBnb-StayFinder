<%layout("/layouts/boilerplate")%>
<head>
    <meta charset="UTF-8">
    <title>About Us | Gobnb</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background: linear-gradient(135deg,#f8f9fa,#e9f2ff);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .about-card{
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .about-card:hover{
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

        h1{
            font-weight: 700;
            color: #2c3e50;
        }

        .tagline{
            font-size: 18px;
            color: #6c757d;
        }

        p{
            font-size: 16px;
            line-height: 1.7;
            color: #444;
        }

        strong{
            color: #0d6efd;
        }

        hr{
            border-top: 2px solid #dee2e6;
            margin: 25px 0;
        }
    </style>
</head>

<body>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            <div class="about-card">

                <h1 class="mb-3 text-center">About Gobnb</h1>

                <p class="text-center tagline">
                    Helping you discover the perfect place to stay, anytime and anywhere.
                </p>

                <hr>

                <p>
                    <strong>Gobnb</strong> is a smart and easy-to-use platform designed to help users
                    find comfortable, affordable, and verified accommodations. Whether you are looking
                    for a short stay, long-term rental, or a budget-friendly option, Gobnb brings
                    the best choices to one place.
                </p>

                <p>
                    Our mission is to simplify the stay-search process by offering clear listings,
                    honest details, and a seamless browsing experience. We focus on transparency,
                    convenience, and user satisfaction at every step.
                </p>

                <p>
                    At Gobnb, we believe that finding a place to stay should be stress-free.
                    That’s why we continuously work to improve our platform and ensure a smooth
                    experience for both guests and property owners.
                </p>

                <p>
                    Thank you for trusting Gobnb. Your comfort is our priority.
                </p>

            </div>

        </div>
    </div>
</div>

</body>
</html>