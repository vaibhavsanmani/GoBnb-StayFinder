<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

/* GLOBAL */
body{
  font-family:'Inter', sans-serif;
  margin:0;
  background:#fff;
  color:#1d1d1f;
  scroll-behavior:smooth;
}

/* NAVBAR (GLASS) */
.navbar{
  position:fixed;
  top:0;
  width:100%;
  padding:15px 40px;
  backdrop-filter:blur(12px);
  background:rgba(255,255,255,0.7);
  display:flex;
  justify-content:space-between;
  z-index:1000;
}
.navbar h4{
  margin:0;
  font-weight:600;
}

/* PROGRESS BAR */
.progress-bar{
  position:fixed;
  top:0;
  left:0;
  height:3px;
  background:#000;
  width:0%;
  z-index:2000;
}

/* HERO PARALLAX */
.hero{
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  background:url('https://images.unsplash.com/photo-1501785888041-af3ef285b470') center/cover;
  color:white;
}
.hero-content{
  transform:translateY(0);
  transition:0.3s;
}
.hero h1{
  font-size:3.5rem;
}

/* TEXT REVEAL */
.reveal span{
  opacity:0;
  display:inline-block;
  transform:translateY(20px);
  transition:0.5s;
}
.reveal.show span{
  opacity:1;
  transform:translateY(0);
}

/* SECTION */
.section{
  padding:100px 20px;
  max-width:1000px;
  margin:auto;
  opacity:0;
  transform:translateY(80px) scale(0.96);
  transition:1.2s cubic-bezier(0.25,1,0.5,1);
}
.section.show{
  opacity:1;
  transform:translateY(0) scale(1);
}

/* CARDS */
.card{
  padding:25px;
  border-radius:18px;
  border:1px solid #e5e5e7;
  background:#fafafa;
  transition:0.3s;
}
.card:hover{
  transform:translateY(-8px);
}

/* GRID */
.row{
  display:flex;
  gap:20px;
  flex-wrap:wrap;
}
.col{
  flex:1;
  min-width:250px;
}

/* BUTTON */
.btn{
  margin-top:20px;
  padding:10px 20px;
  border-radius:30px;
  border:1px solid #ccc;
  background:white;
  cursor:pointer;
}

</style>
</head>

<body>

<div class="progress-bar" id="progress"></div>

<div class="navbar">
  <h4>Gobnb</h4>
  <button onclick="toggleDark()">☾</button>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-content">
    <h1 class="reveal">Find Your Stay</h1>
    <p>Experience comfort worldwide</p>
    <button class="btn" onclick="scrollToNext()">Explore</button>
  </div>
</div>

<!-- ABOUT -->
<div class="section">
  <h2 class="reveal">Our Mission</h2>
  <p>We simplify travel with trusted stays.</p>
</div>

<!-- STEPS -->
<div class="section">
  <h2 class="reveal">How it works</h2>
  <div class="row">
    <div class="col"><div class="card">Search</div></div>
    <div class="col"><div class="card">Compare</div></div>
    <div class="col"><div class="card">Book</div></div>
  </div>
</div>

<!-- STATS -->
<div class="section">
  <h2 class="reveal">Stats</h2>
  <div class="row">
    <div class="col"><div class="card counter" data-target="500">0</div></div>
    <div class="col"><div class="card counter" data-target="1000">0</div></div>
    <div class="col"><div class="card counter" data-target="50">0</div></div>
  </div>
</div>

<script>

/* DARK MODE */
function toggleDark(){
  document.body.classList.toggle("dark");
}

/* SCROLL NEXT */
function scrollToNext(){
  window.scrollBy({top:window.innerHeight, behavior:'smooth'});
}

/* SECTION ANIMATION */
const sections=document.querySelectorAll(".section");
const reveals=document.querySelectorAll(".reveal");

const observer=new IntersectionObserver(entries=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      entry.target.classList.add("show");
    }
  });
},{threshold:0.3});

sections.forEach(s=>observer.observe(s));
reveals.forEach(r=>observer.observe(r));

/* TEXT SPLIT */
document.querySelectorAll(".reveal").forEach(el=>{
  let text=el.innerText;
  el.innerHTML=text.split("").map(char=>`<span>${char}</span>`).join("");
});

/* PARALLAX */
window.addEventListener("scroll",()=>{
  let scrollY=window.scrollY;
  document.querySelector(".hero-content").style.transform=`translateY(${scrollY * 0.3}px)`;
});

/* PROGRESS BAR */
window.addEventListener("scroll",()=>{
  let scrollTop=window.scrollY;
  let docHeight=document.body.scrollHeight - window.innerHeight;
  let progress=(scrollTop/docHeight)*100;
  document.getElementById("progress").style.width=progress+"%";
});

/* COUNTER */
document.querySelectorAll('.counter').forEach(counter=>{
  let update=()=>{
    let target=+counter.dataset.target;
    let current=+counter.innerText;
    let inc=target/100;

    if(current<target){
      counter.innerText=Math.ceil(current+inc);
      setTimeout(update,20);
    }else{
      counter.innerText=target;
    }
  }
  update();
});

</script>

</body>