<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

/* HERO */
.hero{
height:60vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
background:linear-gradient(120deg,#ff4e50,#f9d423);
border-radius:20px;
margin-bottom:60px;
}

.hero h1{
font-size:3rem;
font-weight:700;
}

/* GLASS CARD */
.glass{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(10px);
border-radius:15px;
padding:30px;
box-shadow:0 8px 25px rgba(0,0,0,0.2);
}

/* SECTION TITLE */
.section-title{
font-weight:700;
text-align:center;
margin-bottom:50px;
}

/* HOW IT WORKS */
.step{
text-align:center;
padding:25px;
}

.step-icon{
width:70px;
height:70px;
display:flex;
align-items:center;
justify-content:center;
border-radius:50%;
margin:auto;
background:#ff4e50;
color:white;
font-size:25px;
margin-bottom:15px;
}

/* STATS */
.stat{
text-align:center;
padding:30px;
border-radius:15px;
background:white;
box-shadow:0 10px 20px rgba(0,0,0,0.1);
transition:0.3s;
}

.stat:hover{
transform:translateY(-8px);
}

/* TEAM */
.team{
text-align:center;
padding:30px;
border-radius:15px;
background:white;
box-shadow:0 10px 25px rgba(0,0,0,0.1);
transition:0.3s;
}

.team:hover{
transform:scale(1.05);
}

.team img{
width:90px;
height:90px;
border-radius:50%;
margin-bottom:15px;
}

/* TESTIMONIAL */
.testimonial{
padding:30px;
border-radius:15px;
background:#fff;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
}

/* MOBILE */
@media(max-width:768px){
.hero h1{
font-size:2rem;
}
}

</style>

</head>

<body>

<div class="container mt-5">

<!-- HERO -->
<div class="hero">
<div class="glass">
<h1>Welcome to Gobnb</h1>
<p class="lead">Discover amazing places to stay around the world</p>
</div>
</div>

<!-- ABOUT -->
<div class="row justify-content-center mb-5">
<div class="col-md-8 text-center">

<h2 class="section-title">Our Mission</h2>

<p class="text-muted fs-5">
Gobnb helps travelers discover **affordable and trusted stays**.
We combine modern technology with verified listings to ensure
that every user finds the perfect accommodation with ease.
</p>

</div>
</div>

<!-- HOW IT WORKS -->

<h2 class="section-title">How Gobnb Works</h2>

<div class="row mb-5">

<div class="col-md-4 step">
<div class="step-icon">
<i class="fa-solid fa-search"></i>
</div>
<h5>Search</h5>
<p class="text-muted">Explore thousands of listings easily.</p>
</div>

<div class="col-md-4 step">
<div class="step-icon">
<i class="fa-solid fa-star"></i>
</div>
<h5>Compare</h5>
<p class="text-muted">Check ratings, reviews and amenities.</p>
</div>

<div class="col-md-4 step">
<div class="step-icon">
<i class="fa-solid fa-house"></i>
</div>
<h5>Book</h5>
<p class="text-muted">Reserve your perfect stay instantly.</p>
</div>

</div>

<!-- STATS -->

<h2 class="section-title">Platform Stats</h2>

<div class="row text-center mb-5">

<div class="col-md-4 mb-3">
<div class="stat">
<h2 class="text-danger">500+</h2>
<p class="text-muted">Listings</p>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="stat">
<h2 class="text-success">1000+</h2>
<p class="text-muted">Happy Users</p>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="stat">
<h2 class="text-primary">50+</h2>
<p class="text-muted">Cities</p>
</div>
</div>

</div>

<!-- TEAM -->

<h2 class="section-title">Meet Our Team</h2>

<div class="row justify-content-center mb-5">

<div class="col-md-4 mb-4">
<div class="team">
<img src="https://cdn-icons-png.flaticon.com/512/149/149071.png">
<h5>Vaibhav Sanmani</h5>
<p class="text-muted">Full Stack Developer</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="team">
<img src="https://cdn-icons-png.flaticon.com/512/149/149071.png">
<h5>Team Member</h5>
<p class="text-muted">Backend Developer</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="team">
<img src="https://cdn-icons-png.flaticon.com/512/149/149071.png">
<h5>Team Member</h5>
<p class="text-muted">UI/UX Designer</p>
</div>
</div>

</div>

<!-- TESTIMONIALS -->

<h2 class="section-title">User Experiences</h2>

<div class="row text-center mb-5">

<div class="col-md-4 mb-4">
<div class="testimonial">
<p>"Gobnb helped me find the perfect stay easily."</p>
<strong>Rahul Sharma</strong>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="testimonial">
<p>"Clean listings and trusted reviews. Amazing!"</p>
<strong>Priya Patil</strong>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="testimonial">
<p>"Affordable stays and smooth experience."</p>
<strong>Amit Kulkarni</strong>
</div>
</div>

</div>

</div>

</body>
</html>