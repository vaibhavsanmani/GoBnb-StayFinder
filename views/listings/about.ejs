<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

/* HERO SECTION */
.hero{
    background: linear-gradient(135deg,#fe424d,#ff7a85);
    color:white;
    padding:80px 20px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

/* FEATURE CARDS */
.feature-card{
    transition: all 0.35s ease;
    border-radius:12px;
}

.feature-card:hover{
    transform: translateY(-8px);
    box-shadow:0 15px 30px rgba(0,0,0,0.2);
}

/* STATS */
.stat-box{
    background:white;
    border-radius:12px;
    padding:25px;
    transition:0.3s;
}

.stat-box:hover{
    transform:scale(1.05);
    box-shadow:0 10px 25px rgba(0,0,0,0.15);
}

/* TEAM CARDS */
.team-card{
    border-radius:15px;
    transition:0.35s;
}

.team-card:hover{
    transform: translateY(-6px);
    box-shadow:0 15px 35px rgba(0,0,0,0.2);
}

/* TEAM IMAGE ICON */
.team-icon{
    width:80px;
    height:80px;
    display:flex;
    align-items:center;
    justify-content:center;
    border-radius:50%;
    background:#f1f1f1;
    margin:auto;
}

/* SOCIAL ICONS */
.social-icons a{
    font-size:20px;
    margin:0 8px;
    transition:0.3s;
}

.social-icons a:hover{
    transform:scale(1.2);
}

.social-icons .github:hover{
    color:#000;
}

.social-icons .linkedin:hover{
    color:#0A66C2;
}

.social-icons .instagram:hover{
    color:#E4405F;
}

/* SECTION TITLE */
.section-title{
    font-weight:700;
    letter-spacing:1px;
}

/* MOBILE RESPONSIVE */
@media(max-width:768px){
.hero{
    padding:60px 15px;
}
}

</style>

</head>

<body>

<div class="container mt-5">

<!-- HERO -->
<div class="hero text-center mb-5">
<h1 class="fw-bold display-5">About Gobnb</h1>
<p class="lead">Helping you discover the perfect place to stay.</p>
</div>

<!-- ABOUT TEXT -->
<div class="row justify-content-center mb-5">
<div class="col-md-8 text-center">
<p class="text-muted fs-5">
<strong>Gobnb</strong> is a modern platform designed to help users discover
comfortable and affordable accommodations effortlessly.
</p>

<p class="text-muted">
We simplify the process of finding stays by offering verified listings,
trusted reviews, and detailed property information so users can make
confident travel decisions.
</p>
</div>
</div>

<!-- FEATURES -->
<h2 class="text-center section-title mb-4">Why Choose Gobnb</h2>

<div class="row text-center mb-5">

<div class="col-md-4 mb-4">
<div class="card feature-card border-0 shadow-sm p-4">
<i class="fa-solid fa-house fa-2x text-primary mb-3"></i>
<h5>Verified Listings</h5>
<p class="text-muted">All properties are verified for trust and quality.</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="card feature-card border-0 shadow-sm p-4">
<i class="fa-solid fa-location-dot fa-2x text-danger mb-3"></i>
<h5>Smart Location</h5>
<p class="text-muted">Find stays with accurate and smart location filters.</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="card feature-card border-0 shadow-sm p-4">
<i class="fa-solid fa-star fa-2x text-warning mb-3"></i>
<h5>Trusted Reviews</h5>
<p class="text-muted">Real feedback from real users.</p>
</div>
</div>

</div>

<!-- STATS -->
<div class="row text-center mb-5">

<div class="col-md-4 mb-3">
<div class="stat-box shadow-sm">
<i class="fa-solid fa-building fa-2x text-primary mb-2"></i>
<h2 class="text-primary">500+</h2>
<p class="text-muted">Listings</p>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="stat-box shadow-sm">
<i class="fa-solid fa-users fa-2x text-success mb-2"></i>
<h2 class="text-success">1000+</h2>
<p class="text-muted">Happy Users</p>
</div>
</div>

<div class="col-md-4 mb-3">
<div class="stat-box shadow-sm">
<i class="fa-solid fa-city fa-2x text-danger mb-2"></i>
<h2 class="text-danger">50+</h2>
<p class="text-muted">Cities</p>
</div>
</div>

</div>

</div>

<!-- TEAM SECTION -->

<div class="container mb-5">

<h2 class="text-center section-title mb-5">Our Team</h2>

<div class="row justify-content-center text-center">

<!-- TEAM MEMBER -->
<div class="col-md-4 mb-4">
<div class="card team-card border-0 shadow-sm p-4">

<div class="team-icon mb-3">
<i class="fa-solid fa-user fa-xl text-primary"></i>
</div>

<h5 class="fw-bold">Vaibhav Sanmani</h5>
<p class="text-muted">Full Stack Developer</p>

<div class="social-icons">
<a href="#" class="github"><i class="fa-brands fa-github"></i></a>
<a href="#" class="linkedin"><i class="fa-brands fa-linkedin"></i></a>
<a href="#" class="instagram"><i class="fa-brands fa-instagram"></i></a>
</div>

</div>
</div>

<div class="col-md-4 mb-4">
<div class="card team-card border-0 shadow-sm p-4">

<div class="team-icon mb-3">
<i class="fa-solid fa-user fa-xl text-success"></i>
</div>

<h5 class="fw-bold">Team Member</h5>
<p class="text-muted">Backend Developer</p>

<div class="social-icons">
<a href="#" class="github"><i class="fa-brands fa-github"></i></a>
<a href="#" class="linkedin"><i class="fa-brands fa-linkedin"></i></a>
<a href="#" class="instagram"><i class="fa-brands fa-instagram"></i></a>
</div>

</div>
</div>

<div class="col-md-4 mb-4">
<div class="card team-card border-0 shadow-sm p-4">

<div class="team-icon mb-3">
<i class="fa-solid fa-user fa-xl text-warning"></i>
</div>

<h5 class="fw-bold">Team Member</h5>
<p class="text-muted">UI/UX Designer</p>

<div class="social-icons">
<a href="#" class="github"><i class="fa-brands fa-github"></i></a>
<a href="#" class="linkedin"><i class="fa-brands fa-linkedin"></i></a>
<a href="#" class="instagram"><i class="fa-brands fa-instagram"></i></a>
</div>

</div>
</div>

</div>

</div>

</body>
</html>