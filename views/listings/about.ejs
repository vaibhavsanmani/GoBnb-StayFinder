<%layout("/layouts/boilerplate")%>

<head>
<meta charset="UTF-8">
<title>About | Gobnb</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

/* GLOBAL */
/* ================= GLOBAL ================= */
html{
  scroll-snap-type:y mandatory;
}
body{
  margin:0;
  font-family:'Inter', sans-serif;
  background: linear-gradient(135deg, #e6f7ff, #f5fcff);
  color:#1d1d1f;
  scroll-behavior:smooth;
}

/* ================= NAVBAR ================= */
.navbar{
  position:fixed;
  top:0;
  width:100%;
  padding:15px 40px;
  display:flex;
  justify-content:space-between;
  backdrop-filter:blur(14px);
  background:rgba(230, 247, 255, 0.7);
  border-bottom:1px solid rgba(0,120,160,0.1);
  z-index:1000;
}
.navbar a{
  margin-left:20px;
  text-decoration:none;
  color:#0b3c5d;
  font-weight:500;
}

/* ================= PROGRESS BAR ================= */
.progress-bar{
  position:fixed;
  top:0;
  left:0;
  height:3px;
  background: linear-gradient(90deg, #00b4db, #0083b0);
  width:0%;
  z-index:2000;
}

/* ================= HERO ================= */
.hero{
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  background:
    linear-gradient(rgba(0,150,200,0.4), rgba(0,50,80,0.3)),
    url('https://images.unsplash.com/photo-1501785888041-af3ef285b470') center/cover;
  color:white;
  scroll-snap-align:start;
}
.hero h1{
  font-size:3.5rem;
  letter-spacing:-1px;
}
.hero p{
  opacity:0.9;
}

/* ================= BUTTON ================= */
.btn{
  margin-top:20px;
  padding:12px 24px;
  border-radius:30px;
  border:none;
  background: linear-gradient(135deg, #00b4db, #0083b0);
  color:white;
  cursor:pointer;
  transition:0.3s;
}
.btn:hover{
  transform:scale(1.05);
  box-shadow:0 8px 20px rgba(0,180,220,0.4);
}

/* ================= SECTION ================= */
.section{
  padding:100px 20px;
  max-width:1000px;
  margin:auto;
  opacity:0;
  transform:translateY(80px) scale(0.96);
  transition:1s cubic-bezier(0.25,1,0.5,1);
  scroll-snap-align:start;
}
.section.show{
  opacity:1;
  transform:translateY(0) scale(1);
}

/* ================= TEXT ANIMATION ================= */
.text-fade{
  opacity:0;
  transform:translateY(20px);
  transition:0.8s;
}
.text-fade.show{
  opacity:1;
  transform:translateY(0);
}

/* ================= GRID ================= */
.row{
  display:flex;
  gap:25px;
  flex-wrap:wrap;
}
.col{
  flex:1;
  min-width:250px;
}

/* ================= CARD (ICE GLASS) ================= */
.card{
  padding:30px;
  border-radius:20px;
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(12px);
  border:1px solid rgba(0,150,200,0.15);
  box-shadow:0 5px 20px rgba(0,150,200,0.1);
  transition:0.3s;
}
.card:hover{
  transform:translateY(-10px);
  box-shadow:0 15px 40px rgba(0,150,200,0.2);
}

/* ================= DIVIDER ================= */
.divider{
  height:1px;
  background: linear-gradient(to right, transparent, #bde6ff, transparent);
  margin:80px 0;
}

/* ================= FOOTER ================= */
.footer{
  text-align:center;
  padding:40px;
  color:#4a6b80;
  font-size:14px;
}

/* ================= DARK MODE ================= */
body.dark{
  background: linear-gradient(135deg, #0a1f2e, #123a52);
  color:#e0f7ff;
}

body.dark .navbar{
  background: rgba(10, 30, 50, 0.7);
}

body.dark .card{
  background: rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
}

body.dark .btn{
  background: linear-gradient(135deg, #005f7a, #003f5c);
}

/* ================= SMALL PREMIUM TOUCH ================= */
h1,h2{
  letter-spacing:-0.5px;
}

p{
  font-size:15px;
}

</style>
</head>

<body>

<div class="progress-bar" id="progress"></div>

<div class="navbar">
  <h4>Gobnb</h4>
  <div>
    <a href="/">Home</a>
    <a href="/about">About</a>
    <button onclick="toggleDark()">☾</button>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div>
    <h1 class="text-fade">Find Your Perfect Stay</h1>
    <p class="text-fade">Comfort, luxury, and affordability — all in one place</p>
    <button class="btn" onclick="scrollToNext()">Explore</button>
  </div>
</div>

<!-- ABOUT -->
<div class="section">
  <h2 class="text-fade">Our Mission</h2>
  <p class="text-fade">We help travelers discover the best stays effortlessly.</p>
</div>

<div class="divider"></div>

<!-- STEPS -->
<div class="section">
  <h2 class="text-fade">How it works</h2>
  <div class="row">
    <div class="col"><div class="card">🔍 Search</div></div>
    <div class="col"><div class="card">⭐ Compare</div></div>
    <div class="col"><div class="card">🏠 Book</div></div>
  </div>
</div>

<div class="divider"></div>

<!-- STATS -->
<div class="section">
  <h2 class="text-fade">Stats</h2>
  <div class="row">
    <div class="col"><div class="card counter" data-target="500">0</div></div>
    <div class="col"><div class="card counter" data-target="1000">0</div></div>
    <div class="col"><div class="card counter" data-target="50">0</div></div>
  </div>
</div>

<div class="footer">
  © 2026 Gobnb. All rights reserved.
</div>

<script>

/* DARK MODE */
function toggleDark(){
  document.body.classList.toggle("dark");
}

/* SCROLL */
function scrollToNext(){
  window.scrollBy({top:window.innerHeight, behavior:'smooth'});
}

/* ANIMATION */
const observer=new IntersectionObserver(entries=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      entry.target.classList.add("show");
    }
  });
},{threshold:0.3});

document.querySelectorAll(".section,.text-fade").forEach(el=>{
  observer.observe(el);
});

/* PROGRESS BAR */
window.addEventListener("scroll",()=>{
  let h=document.body.scrollHeight - window.innerHeight;
  let progress=(window.scrollY/h)*100;
  document.getElementById("progress").style.width=progress+"%";
});

/* COUNTER */
document.querySelectorAll('.counter').forEach(counter=>{
  let update=()=>{
    let target=+counter.dataset.target;
    let current=+counter.innerText;
    let inc=target/100;

    if(current<target){
      counter.innerText=Math.ceil(current+inc);
      setTimeout(update,20);
    } else {
      counter.innerText=target;
    }
  }
  update();
});

</script>

</body>