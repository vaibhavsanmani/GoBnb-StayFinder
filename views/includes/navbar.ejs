<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Bootstrap + Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<title>Responsive Navbar</title>

<style>

/* NAVBAR */
.navbar {
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid #eee;
  padding: 10px 15px;
}

/* LOGO */
.logo-img {
  width: 60px;
  height: 60px;
  object-fit: contain;
}

/* SEARCH */
.search-box {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 50px;
  padding: 6px 10px;
  gap: 8px;
  background: #fff;
}
.search-box input {
  border: none;
  outline: none;
  font-size: 13px;
  width: 80px;
}

/* BUTTON */
.search-btn {
  background: #ff385c;
  color: #fff;
  border-radius: 50%;
  border: none;
  width: 32px;
  height: 32px;
}

/* RIGHT */
.nav-right {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

/* HOST BUTTON */
.host-btn {
  padding: 6px 10px;
  border-radius: 20px;
  font-size: 13px;
}

/* MOBILE FIX */
@media (max-width: 768px) {

  .logo-img {
    width: 50px;
    height: 50px;
  }

  .search-box {
    display: none;
  }

  .nav-right {
    width: 100%;
    justify-content: center;
    margin-top: 10px;
  }

  .nav-right a {
    flex: 1;
    text-align: center;
  }
}

</style>
</head>

<body>

<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container-fluid">

    <!-- LOGO -->
    <a class="navbar-brand d-flex align-items-center" href="/listings">
      <img src="/images/go.png" class="logo-img">
    </a>

    <!-- TOGGLE -->
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- NAV CONTENT -->
    <div class="collapse navbar-collapse" id="nav">

      <!-- SEARCH (CENTER) -->
      <div class="mx-auto d-none d-lg-block">
        <form class="search-box">
          <input type="text" placeholder="Anywhere">
          <input type="text" placeholder="Any week">
          <input type="text" placeholder="Guests">
          <button class="search-btn">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </form>
      </div>

      <!-- RIGHT SIDE -->
      <div class="nav-right ms-auto">

        <a href="/listings/new" class="host-btn text-dark text-decoration-none">
          Host <i class="fa-brands fa-airbnb"></i>
        </a>

        <% if(!currUser){ %>
          <a href="/login" class="btn btn-outline-dark rounded-pill">Login</a>
          <a href="/signup" class="btn btn-danger rounded-pill">Signup</a>
        <% } else { %>
          <a href="/logout" class="btn btn-danger rounded-pill">Logout</a>
        <% } %>

      </div>

    </div>

  </div>
</nav>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>