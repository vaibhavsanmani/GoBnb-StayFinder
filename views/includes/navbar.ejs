<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Bootstrap + Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<title>Premium Navbar</title>

<style>

/* NAVBAR (GLASS EFFECT) */
.navbar {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid #eee;
  padding: 12px 40px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

/* LOGO */
.navbar-brand {
  font-size: 22px;
  font-weight: 700;
  color: #fe424d;
}
/* SEARCH BOX */
.search-box {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 50px;
  padding: 6px 10px;
  gap: 10px;
  background: #fff;
  transition: all 0.3s ease;
}

.search-box:hover {
  transform: scale(1.05);
  box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

.search-box input {
  border: none;
  outline: none;
  font-size: 14px;
  width: 100px;
}

/* SEARCH BUTTON */
.search-btn {
  background: linear-gradient(135deg,#ff385c,#fe424d);
  color: #fff;
  border-radius: 50%;
  border: none;
  width: 36px;
  height: 36px;
  transition: 0.3s;
}

.search-btn:hover {
  transform: scale(1.1);
}

/* RIGHT SIDE */
.nav-right {
  display: flex;
  align-items: center;
  gap: 18px;
}

/* HOST BUTTON */
.host-btn {
  padding: 8px 15px;
  border-radius: 25px;
  transition: 0.3s;
  font-weight: 500;
}

.host-btn:hover {
  background: #f7f7f7;
}

/* PROFILE BUTTON */
.profile-btn {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  padding: 6px 12px;
  border-radius: 30px;
  gap: 10px;
  cursor: pointer;
  background: #fff;
  transition: 0.3s;
}

.profile-btn:hover {
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

/* AVATAR */
.avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #ddd;
}

/* DROPDOWN PREMIUM */
.dropdown-menu {
  border-radius: 15px;
  padding: 10px 0;
  border: none;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  animation: fadeSlide 0.3s ease;
}

/* ANIMATION */
@keyframes fadeSlide {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.dropdown-item {
  padding: 10px 20px;
  font-size: 14px;
  transition: 0.2s;
}

.dropdown-item:hover {
  background: #f7f7f7;
  padding-left: 25px;
}

/* MOBILE */
@media (max-width: 768px) {
  .search-box {
    display: none;
  }
}

</style>
</head>

<body>

<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container-fluid">

    <!-- LOGO -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i> Gobnb
    </a>

    <!-- SEARCH -->
    <div class="mx-auto d-none d-lg-block">
      <form class="search-box">
        <input type="text" placeholder="Anywhere">
        <input type="text" placeholder="Any week">
        <input type="text" placeholder="Guests">
        <button class="search-btn">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </form>
    </div>

    <!-- RIGHT -->
    <div class="nav-right ms-auto">

      <!-- PROFILE -->
     <div class="nav-right ms-auto">

  <a href="/listings/new" class="host-btn text-dark text-decoration-none px-3 ">
    Gobnb your home <i class="fa-brands fa-airbnb"></i>
  </a>
  <!-- SIMPLE AUTH BUTTONS -->
  <% if(!currUser){ %>
    <a href="/login" class="btn btn-outline-dark rounded-pill px-3">Login</a>
    <a href="/signup" class="btn btn-danger rounded-pill px-3">Signup</a>
  <% } else { %>
    <a href="/logout" class="btn btn-danger rounded-pill px-2.5">Logout</a>
  <% } %>

</div>

    </div>

  </div>
</nav>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>