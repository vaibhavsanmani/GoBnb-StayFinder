<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- FONT AWESOME -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<!-- GOOGLE FONT -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<title>Responsive Footer</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Inter',sans-serif;
}

/* FOOTER */
.footer{
    background:#1c1c1e;
    color:#e5e5ea;
    padding:50px 20px 20px;
    border-radius:25px 25px 0 0;
    margin-top:60px;
}

/* CONTAINER */
.footer-container{
    display:grid;
    grid-template-columns:1.2fr 2fr 1fr;
    gap:30px;
    align-items:flex-start;
}

/* LEFT */
.footer-left h2{
    font-size:24px;
    color:#fff;
    margin-bottom:10px;
}
.footer-left p{
    font-size:14px;
    color:#a1a1a6;
    line-height:1.6;
}

/* LINKS */
.footer-links{
    display:flex;
    justify-content:space-between;
    gap:20px;
    flex-wrap:wrap;
}
.footer-links h4{
    margin-bottom:10px;
    font-size:14px;
    color:#fff;
}
.footer-links a{
    display:block;
    color:#a1a1a6;
    font-size:13px;
    margin-bottom:6px;
    text-decoration:none;
    transition:0.3s;
}
.footer-links a:hover{
    color:#fff;
    transform:translateX(3px);
}

/* SOCIAL */
.footer-socials h4{
    margin-bottom:10px;
}
.icons{
    display:flex;
    gap:15px;
}
.icons i{
    font-size:18px;
    color:#a1a1a6;
    cursor:pointer;
    transition:0.3s;
}
.icons i:hover{
    color:#fff;
    transform:scale(1.2);
}

/* BOTTOM */
.footer-bottom{
    text-align:center;
    border-top:1px solid #3a3a3c;
    margin-top:30px;
    padding-top:15px;
    font-size:12px;
    color:#8e8e93;
}

/* TABLET */
@media(max-width:992px){
    .footer-container{
        grid-template-columns:1fr 1fr;
    }
    .footer-socials{
        grid-column:span 2;
        text-align:center;
    }
    .icons{
        justify-content:center;
    }
}


/* MOBILE */
@media(max-width:576px){
    .footer{
        padding:40px 15px 15px;
    }

    .footer-container{
        grid-template-columns:1fr;
        text-align:center;
    }

    .footer-links{
        flex-direction:column;
        align-items:center;
        width:100%;
    }

    .footer-links div{
        width:100%;
        text-align:center;
        margin-bottom:15px;
    }

    .footer-links a{
        font-size:14px;
    }

    .icons{
        justify-content:center;
    }

    .footer-left p{
        font-size:13px;
        padding:0 10px;
    }
}
</style>
</head>

<body>

<footer class="footer">
    <div class="footer-container">

        <!-- LEFT -->
        <div class="footer-left">
            <h2>GoBnb</h2>
            <p>Find your perfect stay anywhere in the world with comfort and trust.</p>
        </div>

        <!-- LINKS -->
        <div class="footer-links">

            <div>
                <h4>Company</h4>
                <a href="/about">About</a>
                <a href="#">Careers</a>
                <a href="#">Press</a>
            </div>

            <div>
                <h4>Support</h4>
                <a href="/issues">Help Center</a>
                <a href="#">Safety</a>
                <a href="#">Contact</a>
            </div>

            <div>
                <h4>Legal</h4>
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
            </div>

        </div>

        <!-- SOCIAL -->
        <div class="footer-socials">
            <h4>Follow us</h4>
            <div class="icons">
                <i class="fa-brands fa-facebook"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-linkedin"></i>
            </div>
        </div>

    </div>

    <!-- BOTTOM -->
    <div class="footer-bottom">
        <p>© 2026 GoBnb Private Limited. All rights reserved.</p>
    </div>
</footer>

</body>
</html>